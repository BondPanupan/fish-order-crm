generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL") // remove If you need to run this application on your local
}

// ---- Reference / master data ----------------------------------------

model Customer {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  name        String?
  creditLimit Decimal   @default(0) @db.Decimal(14, 2) @map("credit_limit")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   String?   @map("created_by")
  updatedBy   String?   @map("updated_by")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  orders      Order[]

  @@map("customers")
}

model Item {
  id        String      @id @default(uuid()) @db.Uuid
  code      String      @unique
  name      String?
  unit      String      @default("kg")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  createdBy String?     @map("created_by")
  updatedBy String?     @map("updated_by")
  isDeleted Boolean     @default(false) @map("is_deleted")
  subOrders SubOrder[]
  prices    Price[]
  inventory Inventory[]

  @@map("items")
}

// percentage = price-tier multiplier: EMERGENCY 125 / OVER_DUE 100 / DAILY 90
model OrderType {
  id         String     @id @default(uuid()) @db.Uuid
  code       String     @unique
  name       String?
  priority   Int
  percentage Decimal    @db.Decimal(6, 2)
  subOrders  SubOrder[]
  prices     Price[]

  @@map("order_types")
}

model Supplier {
  id         String      @id @default(uuid()) @db.Uuid
  code       String      @unique
  name       String?
  isWildcard Boolean     @default(false) @map("is_wildcard")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  createdBy  String?     @map("created_by")
  updatedBy  String?     @map("updated_by")
  isDeleted  Boolean     @default(false) @map("is_deleted")
  subOrders  SubOrder[]
  prices     Price[]
  inventory  Inventory[]

  @@map("suppliers")
}

model Warehouse {
  id         String      @id @default(uuid()) @db.Uuid
  code       String      @unique
  name       String?
  isWildcard Boolean     @default(false) @map("is_wildcard")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  createdBy  String?     @map("created_by")
  updatedBy  String?     @map("updated_by")
  isDeleted  Boolean     @default(false) @map("is_deleted")
  subOrders  SubOrder[]
  inventory  Inventory[]

  @@map("warehouses")
}

// ---- Stock & pricing ------------------------------------------------

// Wildcard resolution (SP-000 / WH-000): pick rows ordered by remainingQuantity DESC
model Inventory {
  id                String       @id @default(uuid()) @db.Uuid
  supplierId        String       @db.Uuid @map("supplier_id")
  warehouseId       String       @db.Uuid @map("warehouse_id")
  itemId            String       @db.Uuid @map("item_id")
  remainingQuantity Decimal      @default(0) @db.Decimal(14, 2) @map("remaining_quantity")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  createdBy         String?      @map("created_by")
  updatedBy         String?      @map("updated_by")
  isDeleted         Boolean      @default(false) @map("is_deleted")
  supplier          Supplier     @relation(fields: [supplierId], references: [id])
  warehouse         Warehouse    @relation(fields: [warehouseId], references: [id])
  item              Item         @relation(fields: [itemId], references: [id])
  allocations       Allocation[]

  @@unique([supplierId, warehouseId, itemId])
  @@index([remainingQuantity])
  @@map("inventory")
}

// orderTypeId NULL  = base price (× orderType.percentage at runtime)
// orderTypeId !NULL = explicit override for that tier
model Price {
  id          String     @id @default(uuid()) @db.Uuid
  itemId      String     @db.Uuid @map("item_id")
  supplierId  String     @db.Uuid @map("supplier_id")
  orderTypeId String?    @db.Uuid @map("order_type_id")
  unitPrice   Decimal    @db.Decimal(14, 2) @map("unit_price")
  item        Item       @relation(fields: [itemId], references: [id])
  supplier    Supplier   @relation(fields: [supplierId], references: [id])
  orderType   OrderType? @relation(fields: [orderTypeId], references: [id])

  @@map("prices")
}

// ---- Orders (header) & sub-orders (lines) ---------------------------

model Order {
  id         String     @id @default(uuid()) @db.Uuid
  code       String     @unique
  customerId String     @db.Uuid @map("customer_id")
  remark     String?
  createdAt  DateTime   @default(now()) @map("created_at")
  customer   Customer   @relation(fields: [customerId], references: [id])
  subOrders  SubOrder[]

  @@map("orders")
}

// Each sub-order is one line: a specific item + type + source request under an order
model SubOrder {
  id              String       @id @default(uuid()) @db.Uuid
  code            String       @unique
  orderId         String       @db.Uuid @map("order_id")
  itemId          String       @db.Uuid @map("item_id")
  warehouseId     String       @db.Uuid @map("warehouse_id")
  supplierId      String       @db.Uuid @map("supplier_id")
  requestQuantity Decimal      @db.Decimal(14, 2) @map("request_quantity")
  orderTypeId     String       @db.Uuid @map("order_type_id")
  createDate      DateTime     @db.Date @map("create_date")
  status          String       @default("pending")
  order           Order        @relation(fields: [orderId], references: [id])
  item            Item         @relation(fields: [itemId], references: [id])
  warehouse       Warehouse    @relation(fields: [warehouseId], references: [id])
  supplier        Supplier     @relation(fields: [supplierId], references: [id])
  orderType       OrderType    @relation(fields: [orderTypeId], references: [id])
  allocations     Allocation[]

  @@index([orderId])
  @@index([itemId])
  @@index([orderTypeId])
  @@index([createDate])
  @@index([status])
  @@index([code])
  @@map("sub_orders")
}

// A sub-order can be filled from multiple inventory sources -> one sub_order : many rows
model Allocation {
  id                String    @id @default(uuid()) @db.Uuid
  subOrderId        String    @db.Uuid @map("sub_order_id")
  inventoryId       String    @db.Uuid @map("inventory_id")
  allocatedQuantity Decimal   @db.Decimal(14, 2) @map("allocated_quantity")
  unitPrice         Decimal   @db.Decimal(14, 2) @map("unit_price")
  totalPrice        Decimal   @db.Decimal(14, 2) @map("total_price")
  method            String    @default("auto")
  createdAt         DateTime  @default(now()) @map("created_at")
  subOrder          SubOrder  @relation(fields: [subOrderId], references: [id])
  inventory         Inventory @relation(fields: [inventoryId], references: [id])

  @@index([subOrderId])
  @@index([inventoryId])
  @@map("allocations")
}
